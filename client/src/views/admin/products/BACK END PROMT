exports.getAllOrders = async (businessId, query) => {
  const { search = "", status = "" } = query;

  const where = { businessId };

  // SEARCH
  if (search) {
    where[Op.or] = [
      { id: { [Op.like]: `%${search}%` } },
      { "$customer.name$": { [Op.like]: `%${search}%` } },
      { "$customer.phoneNumber$": { [Op.like]: `%${search}%` } },
    ];
  }

  // FILTER STATUS
  if (status) {
    where.status = status;
  }

  return await Order.findAll({
    where,

    attributes: [
      "id",
      "businessId",
      "customerId",
      "status",
      "totalPrice",

      /*
      =========================
      PAKSA FIELD INI IKUT
      =========================
      */

      "deliveryMethod",
      "deliveryAddress",
      "fulfillmentStatus",

      "createdAt",
      "updatedAt",
    ],

    include: [
      {
        model: Customer,
        as: "customer",
        attributes: ["id", "name", "phoneNumber"],
      },

      {
        model: OrderItem,
        as: "items",
        include: [
          {
            model: ProductVariant,
            as: "variant",

            include: [
              {
                model: Product,
                as: "product",
              },
            ],
          },
        ],
      },
