  },
  required: false
},
      {
        model: Category,
        as: "Category",
        attributes: ["id", "name"]
      }
    ]
  });

  return products.map(p => {
    const variants = p.variants || [];

    const totalStock = variants.reduce(
      (sum, v) => sum + (v.stok || 0),
      0
    );

    const minPrice =
      variants.length > 0
        ? Math.min(...variants.map(v => v.harga))
        : 0;

    return {
      ...p.toJSON(),
      stok: totalStock,
      harga: minPrice 
    };
  });
};

