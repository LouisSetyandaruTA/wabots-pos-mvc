async ({
    sessionId,
    sender,
    message
}) => {

    await ChatMessage.create({
        sessionId,
        sender,
        message
    });

    // UPDATE LAST MESSAGE
    await ChatSession.update(
        {
            lastMessage: message
        },
        {
            where: {
                id: sessionId
            }
        }
    );
};

