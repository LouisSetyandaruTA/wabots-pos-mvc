exports.isValidCustomerName = (name) => {

    if (!name) return false;

    // MINIMAL 2 KARAKTER
    if (name.length < 2) {
        return false;
    }

    // HANYA HURUF DAN SPASI
    const regex = /^[A-Za-z\s]+$/;

    if (!regex.test(name)) {
        return false;
    }

    // MINIMAL ADA 1 HURUF
    const hasLetter = /[A-Za-z]/.test(name);

    if (!hasLetter) {
        return false;
    }

    return true;
};

