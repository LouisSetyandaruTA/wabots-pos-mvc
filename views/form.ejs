<!DOCTYPE html>
<html>
<head>
  <title><%= product ? 'Edit Produk' : 'Tambah Produk' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-5">

  <div class="container max-w-xl mx-auto bg-white p-4 rounded shadow">
    <h2 class="text-lg font-bold mb-4"><%= product ? 'Edit Produk' : 'Tambah Produk' %></h2>

    <form action="<%= product ? '/products/edit/' + product.id : '/products/add' %>" method="POST">
      <div class="mb-3">
        <label class="form-label">Nama Produk</label>
        <input type="text" name="name" value="<%= product ? product.name : '' %>" class="form-control" required>
      </div>
      <div class="mb-3">
        <label class="form-label">Harga</label>
        <input type="number" name="price" value="<%= product ? product.price : '' %>" class="form-control" required>
      </div>
      <div class="mb-3">
        <label class="form-label">Stok</label>
        <input type="number" name="stock" value="<%= product ? product.stock : '' %>" class="form-control" required>
      </div>
      <button type="submit" class="btn btn-success">
        <%= product ? 'Update' : 'Tambah' %>
      </button>
    </form>
  </div>

</body>
</html>