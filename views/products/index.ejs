<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daftar Produk</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
  <div class="container mx-auto p-6">
   <h1 class="text-2xl font-bold mb-4">Daftar Produk</h1>
<a href="/create" class="bg-blue-500 text-white px-4 py-2 rounded mb-4 inline-block">Tambah Produk</a>
<table class="w-full border">
  <thead>
    <tr>
      <th>Nama</th>
      <th>Kategori</th>
      <th>Satuan</th>
      <th>Berat (gr)</th>
      <th>Harga</th>
      <th>Stok</th>
      <th>Aksi</th>
    </tr>
  </thead>
<tbody>
  <% products.forEach(product => { %>
    <tr>
      <td><%= product.nama %></td>
      <td><%= product.kategori %></td>
      <td><%= product.satuan %></td>
      <td><%= product.berat %></td>
      <td><%= product.harga %></td>
      <td><%= product.stok %></td>
      <td>
        <a href="/edit/<%= product.id %>">Edit</a> |
        <form action="/delete/<%= product.id %>" method="POST" onsubmit="return confirm('Yakin ingin menghapus?')">
  <button type="submit" style="color:red; background:none; border:none; cursor:pointer;">Hapus</button>
</form>
      </td>
    </tr>
  <% }) %>
</tbody>
</table>
  </div>
</body>
</html>