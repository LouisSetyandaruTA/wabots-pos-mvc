<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Edit Produk</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="flex bg-gray-100 min-h-screen">
  <!-- Sidebar -->
  <aside class="w-64 bg-white p-6 shadow">
    <h2 class="text-xl font-semibold mb-6">Wabots POS</h2>
    <nav class="space-y-4">
      <a href="/dashboard" class="block text-blue-600 hover:underline">Dashboard</a>
      <a href="/products" class="block font-bold">Produk</a>
      <a href="/logout" class="block text-red-600 hover:underline">Logout</a>
    </nav>
  </aside>

  <!-- Form -->
  <main class="flex-1 p-6">
    <h1 class="text-xl font-bold mb-4">Edit Produk</h1>
    <form action="/products/<%= product.id %>" method="POST" class="space-y-4">
      <input name="nama" value="<%= product.nama %>" class="w-full border px-3 py-2 rounded" required />
      <input name="kategori" value="<%= product.kategori %>" class="w-full border px-3 py-2 rounded" required />
      <input name="satuan" value="<%= product.satuan %>" class="w-full border px-3 py-2 rounded" required />
      <input name="berat" type="number" value="<%= product.berat %>" class="w-full border px-3 py-2 rounded" required />
      <input name="harga" type="number" value="<%= product.harga %>" class="w-full border px-3 py-2 rounded" required />
      <input name="stok" type="number" value="<%= product.stok %>" class="w-full border px-3 py-2 rounded" required />
      <textarea name="keterangan" class="w-full border px-3 py-2 rounded"><%= product.keterangan %></textarea>
      <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">Update</button>
    </form>
  </main>
</body>
</html>