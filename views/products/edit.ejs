<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <title>Edit Produk</title>
    <link rel="stylesheet" href="/css/style.css" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            margin: 0;
            font-family: sans-serif;
            display: flex;
            height: 100vh;
        }

        .sidebar {
            width: 200px;
            background: #333;
            color: white;
            padding: 20px;
            display: flex;
            flex-direction: column;
        }

        .sidebar a {
            color: white;
            text-decoration: none;
            margin: 10px 0;
        }

        .main {
            flex-grow: 1;
            background: #f4f4f4;
            padding: 20px;
        }

        .header {
            background: #222;
            color: white;
            padding: 15px;
            font-size: 20px;
        }

        .cards {
            display: flex;
            gap: 20px;
            margin: 20px 0;
        }

        .card {
            background: white;
            padding: 20px;
            flex: 1;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
            background: white;
        }

        th,
        td {
            padding: 10px;
            border: 1px solid #ccc;
            text-align: left;
        }

        h2 {
            margin-top: 40px;
        }
    </style>
</head>

<body class="flex bg-gray-100 min-h-screen">
    <!-- Sidebar -->
    <div class="sidebar">
        <h3>Wabots POS</h3>
        <a href="/">Dashboard</a>
        <a href="/products">Produk</a>
        <a href="#">Penjualan</a>
        <a href="#">Logout</a>
    </div>

    <!-- Form -->
    <main class="flex-1 p-6">
        <h1 class="text-xl font-bold mb-4">Edit Produk</h1>
        <form action="/products/<%= product.id %>" method="POST" class="space-y-4">
            <input name="nama" value="<%= product.nama %>" class="w-full border px-3 py-2 rounded" required />
            <input name="kategori" value="<%= product.kategori %>" class="w-full border px-3 py-2 rounded" required />
            <input name="satuan" value="<%= product.satuan %>" class="w-full border px-3 py-2 rounded" required />
            <input name="berat" type="number" value="<%= product.berat %>" class="w-full border px-3 py-2 rounded"
                required />
            <input name="harga" type="number" value="<%= product.harga %>" class="w-full border px-3 py-2 rounded"
                required />
            <input name="stok" type="number" value="<%= product.stok %>" class="w-full border px-3 py-2 rounded"
                required />
            <textarea name="keterangan" class="w-full border px-3 py-2 rounded"><%= product.keterangan %></textarea>
            <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">Update</button>
            <a href="/products"
                class="inline-block ml-4 bg-gray-300 text-gray-800 px-4 py-2 rounded hover:bg-gray-400">Batal</a>
        </form>
    </main>
</body>

</html>